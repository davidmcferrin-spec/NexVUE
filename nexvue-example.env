# NexVUE station-wide config — installed as /etc/nexvue/nexvue.env
#
# Sourced by nexvue-encode@.service AFTER the per-channel file, so values here
# override any legacy per-channel copies of the same key. setup.sh installs
# this file only when absent (never overwrites a live station config).
#
# IMPORTANT: this file is SOURCED by bash, so normal shell quoting rules apply.

# Channel count of the installed DeckLink card (input validation for
# INPUT_TYPE=decklink). Duo 2 / Duo 2 Mini = 4, Quad 2 = 8, original Duo = 2.
# Default: 8
MAX_DEVICES=8

# Encoder / Settings slots (0 .. MAX_CHANNELS-1). Independent of the DeckLink
# card — SRT-only channels can use ids above MAX_DEVICES-1 (e.g. @8 and @9).
# Default: 10
MAX_CHANNELS=10

# Floating LO (adaptive) rendition pool. Channels may set LO_ENABLE=true, but
# only the first MAX_LO_RENDITIONS requesters by ascending channel id actually
# build the LO tee (UI also caps enables at this number). Default: 6
MAX_LO_RENDITIONS=6

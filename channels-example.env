# /etc/nexvue/channels/<n>.env — one file per enabled channel.
# The systemd instance name selects the file: nexvue-encode@0 -> 0.env
#
# Copy this file to 0.env .. 7.env and adjust per channel.

# --- Required -----------------------------------------------------------------
DEVICE_NUMBER=0        # DeckLink Quad 2 connector index (0-7)
CHANNEL_PATH=ch0       # MediaMTX path; keep = device number for sanity

# --- Optional (defaults shown) --------------------------------------------------
# Output cadence from 1080i59.94 source:
#   all -> 1080p59.94  (program, director, talent return — full motion)
#   top -> 1080p29.97  (multiview walls, prompter — half the encode load)
#DEINT_FIELDS=all

#BITRATE_KBPS=5000     # 4000-6000 typical for 1080p59.94; 2500-3000 for 29.97p
#GOP_FRAMES=60         # keyframe interval; affects viewer JOIN time only —
                       # 30 = faster channel switching, not lower latency
#ENABLE_AUDIO=true     # false removes the browser A/V-sync buffer (~40-60ms
                       # saved) — recommended for prompter/multiview channels
#AUDIO_FRAME_MS=10     # Opus frame size; 10ms is the low-latency default
#AUDIO_BITRATE_BPS=128000
#AUDIO_CHANNELS=2      # SDI embedded pairs to capture (2, 8, or 16)
#DECKLINK_BUFFER_FRAMES=2  # driver frame queue; keep small for latency
#VIDEO_ENCODER=vah264enc   # x264enc = CPU fallback for bring-up/debug only
#EXTRA_ENC_ARGS=       # extra encoder properties if needed (e.g. cpb-size)
#RTSP_URL=rtsp://127.0.0.1:8554/ch0

# --- LO rendition (adaptive-bandwidth fallback) ----------------------------------
# Publishes a second, lower-bitrate encode of the same input as <path>lo
# (e.g. ch0lo). The portal player switches to it when viewer-side stats show
# sustained loss. Enable on channels served to external/cellular viewers.
# NOTE: this is a tee inside the same pipeline — DeckLink inputs are
# exclusive-open, so never try to run a second service on the same device.
#LO_ENABLE=false
#LO_PRESET=720p        # 720p|540p|480p|360p|240p|180p — 16:9 ladder with sane
                       # default bitrates (1200/800/700/500/300/200 kbps).
                       # Remember: the "p" number is the HEIGHT (480p=854x480).
#LO_WIDTH=             # explicit raster overrides the preset (must be even)
#LO_HEIGHT=
#LO_BITRATE_KBPS=      # explicit bitrate overrides the preset default
#LO_FPS=30000/1001
# NexVUE channel config — copy to /etc/nexvue/channels/<N>.env, one per input.
# The systemd instance number selects the file: nexvue-encode@1 -> 1.env
#
# IMPORTANT: this file is SOURCED by bash (nexvue-encode@.service's ExecStart),
# so normal shell quoting rules apply. Any value containing spaces or other
# shell-special characters MUST be quoted, or bash runs the rest of the line
# as a command and silently drops it from the value.
#
#   OK:    CHANNEL_ALIAS="TVU 35"
#   BAD:   CHANNEL_ALIAS=TVU 35    # bash runs `35` as a command; alias = "TVU"
#
# Inline "# comments" after a value are tolerated (shell semantics), but
# keeping comments on their own lines is still the safest style.

# ============================ REQUIRED ============================

# DeckLink connector index, 0-based.
#   Duo 2 / Duo 2 Mini: 0-3    Quad 2: 0-7
# Only enable nexvue-encode@N when this connector is patched as Input with a
# feed — or leave it enabled empty and Phase 1.5 serves a NO SIGNAL slate.
# Station-wide MAX_DEVICES lives in /etc/nexvue/nexvue.env (not per channel).
DEVICE_NUMBER=0

# MediaMTX path for this channel (keep it equal to the device number for sanity).
CHANNEL_PATH=ch0

# Optional friendly label for UIs (player / multiview / channels). Does not
# change the MediaMTX path — WHEP still uses CHANNEL_PATH (ch0, ch1, …).
# Quote it if it contains spaces (this file is sourced by bash).
#CHANNEL_ALIAS="Prompter A"

# ============================ OPTIONAL ============================
# Uncomment and set as needed. Defaults shown in the comment above each key.

# Output cadence from a 1080i59.94 source.
#   all -> 1080p59.94 (full motion: program, director, talent return)
#   top -> 1080p29.97 (half encode cost: multiview walls, prompter)
# Default: all
#DEINT_FIELDS=all

# HI-rendition video bitrate, kbps CBR.
#   4000-6000 typical for 1080p59.94; 2500-3000 for 29.97p.  Default: 5000
#BITRATE_KBPS=5000

# Keyframe interval in frames. Affects viewer JOIN time only, not steady-state
# latency. 30 = faster channel switching.  Default: 60
#GOP_FRAMES=60

# Audio. false removes the browser A/V-sync buffer (~40-60ms lower latency) —
# recommended for prompter/multiview channels.  Default: true
#ENABLE_AUDIO=true

# Opus frame size in ms (2,5,10,20,40,60). 10 is the low-latency default.
#AUDIO_FRAME_MS=10

# Opus bitrate in bps.  Default: 128000
#AUDIO_BITRATE_BPS=128000

# SDI embedded audio pairs to capture (2, 8, or 16).  Default: 2
#AUDIO_CHANNELS=2

# DeckLink driver frame queue depth. Keep small for latency.  Default: 2
#DECKLINK_BUFFER_FRAMES=2

# Video encoder. x264enc is a CPU fallback for bring-up/debug only.
# Default: vah264enc
#VIDEO_ENCODER=vah264enc

# Extra encoder properties if needed (e.g. cpb-size).  Default: empty
#EXTRA_ENC_ARGS=

# Override the RTSP publish URL.  Default: rtsp://127.0.0.1:8554/<CHANNEL_PATH>
#RTSP_URL=rtsp://127.0.0.1:8554/ch0

# -------------------- LO rendition (adaptive bandwidth) --------------------
# Publishes a second, lower-bitrate encode of the same input as <path>lo
# (e.g. ch0lo). The portal player switches to it under sustained loss. Enable
# on channels served to external/cellular viewers.
# NOTE: this is a tee in the same pipeline — DeckLink inputs are exclusive-open,
# so never try to run a second service on the same device.

# Default: false
#LO_ENABLE=false

# LO resolution preset: 720p|540p|480p|360p|240p|180p — 16:9 ladder with sane
# default bitrates (2500/1500/1200/800/500/350 kbps). The "p" number is the
# HEIGHT (480p=854x480).  Default: 720p
#LO_PRESET=720p

# Explicit raster overrides the preset (must be even numbers).
#LO_WIDTH=
#LO_HEIGHT=

# Explicit bitrate (kbps) overrides the preset default.
#LO_BITRATE_KBPS=

# LO framerate.  Default: 30000/1001 (29.97p, cellular-friendly)
#LO_FPS=30000/1001

# vah264enc quality vs speed for LO only (1=best .. 7=fastest). HI stays at 7
# for latency. Default 4 — smoother motion without matching HI GPU cost.
#LO_TARGET_USAGE=4

# Deeper LO video queue (buffers) so scale/encode under iGPU pressure drops
# fewer frames. HI branch keeps a shallow queue. Default: 16
#LO_QUEUE_BUFFERS=16

# Optional LO keyframe interval; blank inherits GOP_FRAMES.
#LO_GOP_FRAMES=

# -------------------- Captions (selectable overlay, not burn-in) --------------------
# Extracts CEA-608/CC1 (including 608 carried inside 708 CDP) in the same
# encode pipeline and publishes timed text to /run/nexvue/captions/<path>.json
# for nexvue-captions.php → Player/Multiview CC toggle. No extra video
# stream and nothing burned into H.264. Probe a feed with:
#   sudo -u nexvue nexvue-captions-probe.sh <device-number>
# Default: true
#CAPTIONS_ENABLE=true

# -------------------- Phase 1.5 supervisor (DeckLink ↔ slate) --------------------
# Seconds of continuous unlock before LIVE → NO SIGNAL slate. Keep generous so
# brief hiccups heal as black frames (default matches stable Phase 1 behavior).
#SIGNAL_LOSS_DEBOUNCE_S=15

# Seconds of continuous lock + valid video before SLATE → LIVE.
#SIGNAL_ACQUIRE_DEBOUNCE_S=1

# Seconds before rebuilding a DeckLink branch after a hard ERROR/EOS.
#DECKLINK_RETRY_S=3

# Optional Gst watchdog on the DeckLink video branch (ms). Default 0 = off.
# Signal property + SIGNAL_LOSS_DEBOUNCE_S own hiccup handling. If you enable
# this, keep it ≥ (SIGNAL_LOSS_DEBOUNCE_S + 5) * 1000 — the supervisor clamps
# shorter values up so a 3s watchdog cannot restart-storm past a 15s debounce.
#WATCHDOG_MS=0
